# ============================================================================
# STREAMLIT SECRETS CONFIGURATION FOR GITHUB WAIVER STORAGE
# ============================================================================
# This file shows the format for configuring persistent waiver storage.
# 
# FOR LOCAL DEVELOPMENT:
# 1. Copy this file to .streamlit/secrets.toml (remove .example)
# 2. Fill in your actual GitHub token and repository name
# 3. Streamlit will automatically load these when you run the app
#
# FOR STREAMLIT CLOUD:
# 1. Go to https://share.streamlit.io/
# 2. Select your app
# 3. Click "Settings" (gear icon in top-right)
# 4. Click "Secrets" tab
# 5. Paste the content below (without the file extension)
# 6. Click "Save"
#
# ============================================================================

# Your GitHub Personal Access Token
# Create at: https://github.com/settings/tokens
# Required scopes: "repo" (full control of private repositories)
# Keep this PRIVATE - never commit to public repositories
GITHUB_TOKEN = "ghp_your_token_here"

# Your repository in format "owner/repo"
# Example: "gldun/CodeYouAICapstone"
# Waivers will be stored in: waivers/{event_name}/ directory
GITHUB_REPO = "owner/repo-name"

# ============================================================================
# HOW TO GET YOUR GITHUB_TOKEN:
# ============================================================================
# 1. Go to https://github.com/settings/tokens
# 2. Click "Generate new token" → "Generate new token (classic)"
# 3. Set a descriptive name: "Streamlit Waiver Storage"
# 4. Set expiration (recommended: 90 days for security)
# 5. Select scopes:
#    - Check "repo" (full control of private repositories)
# 6. Click "Generate token"
# 7. COPY THE TOKEN IMMEDIATELY (you won't see it again!)
# 8. Paste it in GITHUB_TOKEN = "..." above
#
# ============================================================================
# WAIVER STORAGE BEHAVIOR:
# ============================================================================
# When a youth signs a waiver:
# 1. App checks for GITHUB_TOKEN and GITHUB_REPO
# 2. If both are configured:
#    - Waiver JSON is committed to GitHub
#    - Persistent URL is returned
#    - Waivers survive across restarts and deployments
# 3. If GitHub unavailable or config missing:
#    - Falls back to local file storage
#    - Works on local development
#    - WILL NOT PERSIST on Streamlit Cloud (ephemeral container)
#
# File structure in GitHub:
# waivers/
#   {event-name}/
#     waiver_participant_20260329_104634.json
#     waiver_participant_20260329_110215.json
#
# ============================================================================
